/**
 * 获取{{.StructDoc}}列表（分页）（对应 /{{.ModulePath}}/list）
 * @param params 搜索参数
 * @returns {{.StructDoc}}列表
 */
export function fetchGet{{.EntityName}}List(params?: Api.{{.ModuleNamespace}}.{{.EntityName}}SearchParams) {
  return request.get<Api.{{.ModuleNamespace}}.{{.EntityName}}ListResponse>({
    url: '/api/{{.ModulePath}}/list',
    params
  })
}


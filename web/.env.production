# 【生产】环境变量

# 权限模式（与 .env 对齐；未设置时可能被误判为 backend，导致动态路由为空）
VITE_ACCESS_MODE = frontend

# 应用部署基础路径。
# - 使用 ./ 时，打包出的 index.html 为相对路径 ./assets/...，可直接双击打开 dist、或挂在任意子路径，避免 /assets 404 白屏。
# - 若必须固定站点根路径且仅通过 http(s) 根路径访问，可改为 /
VITE_BASE_URL = /

# API 地址前缀
VITE_API_URL = /

# Delete console
VITE_DROP_CONSOLE = true